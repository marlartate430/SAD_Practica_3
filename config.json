
{
    "data": "datos.csv",
    "target": "Sentimiento",
    "preproceso": {
        "target": "Sentimiento",
        "categoria": ["id", "double", "double", "string", "text"],
        "drop_columns": [],
        "drop_duplicates": true,
        "missing_values": "impute",
        "impute_strategy": ["mode", "median", "mode"],
        "outliers": "impute",
        "outlier_strategy": ["max-min", "median"],
        "scaling": ["min-max", "z-score"],
        "categorical_encoding": "label",
        "text_process": "basic_clean",
        "normalize_strategy": "basic",
        "text_encoding": "frequency",
        "sampling_strategy": "oversampling",
        "sampling_ratio": 0.3,
        "sampling_seed": 42
    },

    "arbol_decision" : {
        "criterion": "gini",
        "splitter": "best",
        "max_depth": [3, 6, 9],
        "min_samples_split": 2, // Este es el maximo valor en el barrido de este hiperparametro
        "min_samples_leaf": 2 // Este es el maximo valor en el barrido de este hiperparametro
    }

}