{
    "train": "train.csv",
    "test": "test.csv",
    "preproceso": {
        "target": "Sentimiento",
        "drop_columns": ["XYZ-0"],
        "categoria": ["id", "int", "double", "string", "text", "string"],
        "drop_duplicates": true,
        "erroneous_values": {
            "action": "impute",
            "rules": {
                "Edad": {
                    "conditions": [
                        {"type": "less_than", "value": 0},
                        {"type": "greater_than", "value": 110},
                        {"type": "has_decimals", "value": true}
                    ],
                    "strategy": "median"
                },
                "Ingresos": {
                    "conditions": [
                        {"type": "less_than", "value": 0},
                        {"type": "greater_than", "value": 500000},
                        {"type": "has_decimals", "value": false}
                    ],
                    "strategy": "median"
                },
                "Categoria": {
                    "conditions": [
                        {"type": "regex", "value": "[^a-zA-Z0-9\\s]"},
                        {"type":  "in_list", "value":  ["error", "indefinido"]}
                    ],
                    "strategy": "mode"
                }
            }
        },
        "missing_values": "impute",
        "impute_strategy": ["median", "mean", "mode", "none", "none"],
        "outliers": "impute",
        "outlier_strategy": ["max-min", "median"],
        "scaling": ["min-max", "z-score"],
        "categorical_encoding": "one-hot",
        "text_process": "basic_clean",
        "normalize_strategy": "basic",
        "text_encoding": "tf-idf",
        "sampling_strategy": "oversample",
        "sampling_ratio": "auto",
        "sampling_seed": 42
    },
    "knn": {
        "n_neighbors": [3, 5, 7, 9, 11, 15],
        "weights": ["uniform", "distance"],
        "p": [1, 2],
        "test_size": 0.2,
        "random_seed": 42
    }
}