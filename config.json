{
    "algoritmos_a_usar": ["decision_trees"],
    "train": "penguins_train.csv",
    "test": "penguins_test.csv",
    "preproceso": {
        "target": "species",
        "drop_columns": "",
        "categoria": ["string", "string", "double", "double", "double", "string"],
        "drop_duplicates": true,
        "erroneous_values": {
            "action": "impute",
            "rules": {
                "Edad": {
                    "conditions": [
                        {"type": "less_than", "value": 0},
                        {"type": "greater_than", "value": 110},
                        {"type": "has_decimals", "value": true}
                    ],
                    "strategy": "median"
                },
                "Ingresos": {
                    "conditions": [
                        {"type": "less_than", "value": 0},
                        {"type": "greater_than", "value": 500000},
                        {"type": "has_decimals", "value": false}
                    ],
                    "strategy": "median"
                },
                "Categoria": {
                    "conditions": [
                        {"type": "regex", "value": "[^a-zA-Z0-9\\s]"},
                        {"type":  "in_list", "value":  ["error", "indefinido"]}
                    ],
                    "strategy": "mode"
                }
            }
        },
        "missing_values": "impute",
        "impute_strategy": ["median", "mode", "mode", "mode", "mode"],
        "outliers": "impute",
        "outlier_strategy": ["max-min", "median", "median", "median", "median"],
        "scaling": ["min-max", "min-max"],
        "categorical_encoding": "one-hot",
        "text_process": "basic_clean",
        "normalize_strategy": "basic",
        "text_encoding": "tf-idf",
        "sampling_strategy": "oversample",
        "sampling_ratio": "auto",
        "sampling_seed": 42
    },
    "knn": {
        "n_neighbors": [1, 3, 5, 7, 9, 11, 15],
        "weights": ["uniform", "distance"],
        "p": [1, 2],
        "test_size": 0.2,
        "scoring": "f1_macro",
        "cv_folds": 5,
        "use_k_fold": true
    },
    "naive_bayes": {
        "model_type": "gaussian",
        "var_smoothing": [1e-11, 1e-10, 1e-9, 1e-8, 1e-7, 1e-6],
        "test_size": 0.2,
        "scoring": "f1_macro",
        "cv_folds": 5,
        "use_k_fold": true
    },

    "decision_trees" : {
        "regression" : false,
        "criterion": ["gini","gini", "gini"],
        "splitter": ["best","best","best"],
        "max_depth": [3, 6, 9],
        "min_samples_split": 2,
        "min_samples_leaf": 2
    },

    "random_forest" : {
        "regression" : false,
        "n_stimators" : [5],
        "criterion" : ["gini"],
        "max_depth" : [3],
        "min_samples_split": 2,
        "min_samples_leaf": 2,
        "max_features" : ["sqrt"]
    }
}