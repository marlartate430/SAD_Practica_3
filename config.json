{
    "algoritmos_a_usar": ["knn", "decision_trees", "random_forest", "logistic_regression", "naive_bayes"],
    "train": "penguins_train.csv",
    "test": "penguins_test.csv",
    "preproceso": {
        "target": "species",
        "drop_columns": "",
        "categoria": ["string", "string", "double", "double", "double", "string"],
        "drop_duplicates": true,
        "erroneous_values": {
            "action": "impute",
            "rules": {
                "bill_length_mm": {
                    "conditions": [
                        {"type": "less_than", "value": 0},
                        {"type": "greater_than", "value": 100},
                        {"type": "has_decimals", "value": false}
                    ],
                    "strategy": "median"
                },
                "bill_depth_mm": {
                    "conditions": [
                        {"type": "less_than", "value": 0},
                        {"type": "greater_than", "value": 500},
                        {"type": "has_decimals", "value": false}
                    ],
                    "strategy": "median"
                },
                "island": {
                    "conditions": [
                        {"type": "regex", "value": "[^a-zA-Z0-9\\s]"},
                        {"type":  "in_list", "value":  ["error", "indefinido"]}
                    ],
                    "strategy": "mode"
                }
            }
        },
        "missing_values": "impute",
        "impute_strategy": ["median", "mode", "mode", "mode", "mode"],
        "outliers": "impute",
        "outlier_strategy": ["max-min", "median", "median", "median", "median"],
        "scaling": ["min-max", "min-max"],
        "categorical_encoding": "one-hot",
        "text_process": "basic_clean",
        "normalize_strategy": "basic",
        "text_encoding": "tf-idf",
        "sampling_strategy": "oversample",
        "sampling_ratio": "auto",
        "sampling_seed": 42
    },
    "knn": {
        "n_neighbors": [1, 3, 5, 7, 9, 11, 15],
        "weights": ["uniform", "distance"],
        "p": [1, 2],
        "test_size": 0.2,
        "scoring": "f1_macro",
        "use_k_fold": true,
        "cv": 5
    }
}